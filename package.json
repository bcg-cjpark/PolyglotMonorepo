{
  "name": "@monorepo/root",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "graph": "nx graph",
    "affected": "nx affected",
    "web": "nx run web:dev",
    "web:build": "nx run web:build",
    "web:test": "nx run web:test",
    "web:lint": "nx run web:lint",
    "web:e2e": "nx run web:e2e",
    "api": "nx run api:serve",
    "api:build": "nx run api:build",
    "api:test": "nx run api:test",
    "api:lint": "nx run api:lint",
    "ui": "pnpm --filter @monorepo/ui storybook",
    "ui:build": "pnpm --filter @monorepo/ui build-storybook",
    "storybook": "pnpm --filter @monorepo/ui storybook"
  },
  "devDependencies": {
    "@nx/js": "^20.0.0",
    "@nx/react": "^20.0.0",
    "@nx/vite": "^20.0.0",
    "@nx/workspace": "^20.0.0",
    "nx": "^20.0.0",
    "openapi-typescript": "^7.4.0",
    "typescript": "~5.5.2"
  }
}
