# ── Database (MySQL 8.x) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=polyglot_example
DB_USER=root
DB_PASSWORD=change-me

# ── API ──
SPRING_PROFILES_ACTIVE=dev
API_PORT=8080
JWT_SECRET=change-me-in-production-min-32-chars

# ── Web (dev) ──
# 프론트엔드는 항상 `/api` 상대 경로로 호출합니다.
# Vite dev server가 이 값으로 `/api/*` 요청을 프록시합니다.
VITE_API_TARGET=http://localhost:8080
